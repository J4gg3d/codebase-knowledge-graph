{
  "name": "markdown-graph-visualizer",
  "version": "0.1.0",
  "description": "Visualize Markdown files as interactive knowledge graphs",
  "type": "module",
  "scripts": {
    "dev": "node dev.mjs",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cytoscape": "^3.31.0",
    "cytoscape-fcose": "^2.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4"
  }
}
